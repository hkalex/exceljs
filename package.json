{
  "name": "exceljs",
  "version": "4.4.0",
  "description": "Excel Workbook Manager - Read and Write xlsx and csv Files.",
  "private": false,
  "license": "MIT",
  "author": {
    "name": "Guyon Roche",
    "email": "guyon@live.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/exceljs/exceljs.git"
  },
  "engines": {
    "node": ">=8.3.0"
  },
  "main": "./excel.js",
  "browser": "./dist/exceljs.min.js",
  "types": "./index.d.ts",
  "files": [
    "dist",
    "lib",
    "excel.js",
    "LICENSE",
    "README.md",
    "README_zh.md",
    "index.ts",
    "index.d.ts"
  ],
  "scripts": {
    "test": "npm run test:full",
    "test:es5": "export EXCEL_BUILD=es5 && npm run test:full",
    "test:full": "npm run build && npm run test:unit && npm run test:integration && npm run test:end-to-end && npm run test:browser && npm run test:dist",
    "test:version": "npm run build && npm run test:unit && npm run test:integration && npm run test:end-to-end && npm run test:dist",
    "test:all": "npm run test:native && npm run test:es5",
    "test:native": "npm run test:full",
    "test:unit": "mocha --require spec/config/setup --require spec/config/setup-unit spec/unit --recursive",
    "test:integration": "mocha --require spec/config/setup spec/integration --recursive",
    "test:end-to-end": "mocha --require spec/config/setup spec/end-to-end --recursive",
    "test:browser": "npm run build && mocha --require spec/config/setup spec/browser/browser.spec.js",
    "test:unit:es5": "export EXCEL_BUILD=es5 && npm run test:unit",
    "test:integration:es5": "export EXCEL_BUILD=es5 && npm run test:integration",
    "test:end-to-end:es5": "export EXCEL_BUILD=es5 && npm run test:end-to-end",
    "test:dist": "mocha --require spec/config/setup spec/dist --recursive",
    "test:manual": "node spec/manual/app.js",
    "test:typescript": "NODE_OPTIONS='--no-experimental-strip-types' mocha -r ts-node/register/transpile-only spec/typescript/**/*.spec.ts",
    "clean-build": "npm run clean && npm run build",
    "lint": "eslint --format stylish .",
    "lint:fix": "prettier --write . && eslint --fix .",
    "lint:staged": "lint-staged",
    "clean": "rm -rf build/ && rm -rf dist",
    "benchmark": "node --expose-gc benchmark",
    "benchmark:debug": "node --expose-gc --inspect-brk --trace-deopt benchmark",
    "build": "node build.js",
    "install-build": "npm install && node build.js",
    "preversion": "npm run clean && npm run build && npm run test:version",
    "postversion": "git push --no-verify && git push --tags --no-verify",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "keywords": [
    "xlsx",
    "json",
    "csv",
    "excel",
    "font",
    "border",
    "fill",
    "number",
    "format",
    "number format",
    "alignment",
    "office",
    "spreadsheet",
    "workbook",
    "defined names",
    "data validations",
    "rich text",
    "in-cell format",
    "outlineLevel",
    "views",
    "frozen",
    "split",
    "pageSetup"
  ],
  "dependencies": {
    "archiver": "^5.0.0",
    "dayjs": "^1.11.13",
    "fast-csv": "^4.3.1",
    "jszip": "^3.10.1",
    "readable-stream": "^3.6.0",
    "saxes": "^5.0.1",
    "unzipper": "^0.10.11",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@eslint/js": "^9.39.4",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.0",
    "babelify": "^10.0.0",
    "browserify": "^17.0.1",
    "chai": "^4.5.0",
    "chai-datetime": "^1.8.0",
    "chai-xml": "^0.4.1",
    "core-js": "^3.41.0",
    "dirty-chai": "^2.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.21.0",
    "exorcist": "^2.0.0",
    "express": "^4.21.2",
    "glob": "^13.0.6",
    "globals": "^16.0.0",
    "got": "^11.8.5",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^15.5.2",
    "mocha": "^11.7.6",
    "prettier": "^3.9.4",
    "regenerator-runtime": "^0.14.1",
    "sax": "^1.4.1",
    "terser": "^5.49.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "elliptic": "file:shims/elliptic",
    "exorcist": {
      "minimist": "^1.2.8"
    },
    "fstream": "file:shims/fstream",
    "glob": "^13.0.6",
    "lodash.isequal": "file:shims/lodash.isequal",
    "mocha": {
      "diff": "^8.0.3",
      "serialize-javascript": "^7.0.5"
    }
  }
}
